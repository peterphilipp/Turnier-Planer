# === Pflicht ===
# JWT-Secret zum Signieren/Verifizieren der Tokens.
# MUSS gesetzt sein (mind. 16 Zeichen) – der Server startet sonst NICHT.
# Sicheres Secret erzeugen z.B. mit: openssl rand -hex 32
JWT_SECRET="bitte-durch-ein-langes-zufaelliges-secret-ersetzen"

# Prisma/SQLite Datenbank
DATABASE_URL="file:./prisma/data/dev.db"

# === Optional ===
# Basis-URL des Frontends (für Passwort-Reset-Links)
FRONTEND_URL="http://localhost:5173"

# E-Mail-Versand über Resend (Passwort-Reset). Ohne Key wird der Versand übersprungen.
RESEND_API_KEY=""
EMAIL_FROM="Turnier-Planer <noreply@turnier-planer.mygate.dedyn.io>"

# Kommagetrennte E-Mails, die beim Login/Registrieren automatisch ADMIN werden
ADMIN_EMAILS="peter.philipp@example.com,admin@example.com"
